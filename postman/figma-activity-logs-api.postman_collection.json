                  "type": "oauth2",
                  "oauth2": [
                    {
                      "key": "scope",
                      "value": "org:activity_log_read",
                      "type": "string"
                    },
                    {
                      "key": "accessTokenUrl",
                      "value": "https://api.figma.com/v1/oauth/token",
                      "type": "string"
                    },
                    {
                      "key": "authUrl",
