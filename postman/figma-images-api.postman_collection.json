  "info": {
    "_postman_id": "94316d3c-9454-49fe-814e-8aa0fd815381",
    "name": "Figma Images API",
    "description": "Figma allows designers to create and prototype their digital experiences -\ntogether in real-time and in one place - helping them turn their ideas and\nvisions into products, faster. Figma's mission is to make design\naccessible to everyone. The Figma API is one of the ways we aim to do\nthat.\n\nContact Support:\n Email: support@figma.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:08:39.000Z",
    "updatedAt": "2026-06-05T15:08:39.000Z",
