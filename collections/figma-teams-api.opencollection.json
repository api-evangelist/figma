{
  "opencollection": "1.0.0",
  "info": {
    "name": "Figma Teams API",
    "version": "0.21.0"
  },
  "items": [
    {
      "info": {
        "name": "Teams",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Figma Get Team Webhooks",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.figma.com/v2/teams/:team_id/webhooks",
            "params": [
              {
                "name": "team_id",
                "value": "team_12345678",
                "type": "path",
                "description": "ID of team to get webhooks for"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Returns all webhooks registered under the specified team."
        }
      ]
    }
  ],
  "bundled": true
}