{
  "opencollection": "1.0.0",
  "info": {
    "name": "Figma Component Sets API",
    "version": "0.21.0"
  },
  "items": [
    {
      "info": {
        "name": "Component Sets",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Figma Get Component Set",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.figma.com/v1/component_sets/:key",
            "params": [
              {
                "name": "key",
                "value": "abc123def456",
                "type": "path",
                "description": "The unique identifier of the component set."
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Get metadata on a component set by key."
        }
      ]
    }
  ],
  "bundled": true
}